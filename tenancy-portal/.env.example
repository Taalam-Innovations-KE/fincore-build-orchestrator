TENANT_PORTAL_IMAGE=taalamke/taalam-tenants-portal:latest

# NextAuth
# Generate a random secret: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET
AUTH_URL=https://tenants.patocapital.com

# Keycloak (platform realm = control plane)
AUTH_KEYCLOAK_ISSUER=https://auth.patocapital.com/realms/platform
AUTH_KEYCLOAK_ID=tenants-portal
AUTH_KEYCLOAK_SECRET=CHANGE_ME_PORTAL_CLIENT_SECRET

# Tenancy management API (internal, not publicly exposed)
TENANT_MGMT_API_BASE_URL=http://fineract-tenant-management-service:8080
