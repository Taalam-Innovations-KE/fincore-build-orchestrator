FINERACT_NODE_ID=1
FINERACT_IMAGE=taalamke/taalam-fineract:latest
FINERACT_CONTAINER_USER=0:0

# --- Tenant runtime (register-and-refresh) endpoint, secured by Keycloak JWT ---
# tenancy-service calls this with a client-credentials token (client fineract-runtime).
TAALAM_TENANT_RUNTIME_ENABLED=true
TAALAM_TENANT_RUNTIME_JWK_SET_URI=http://fincore-kc:8080/realms/platform/protocol/openid-connect/certs
TAALAM_TENANT_RUNTIME_AUDIENCE=fineract

# --- Authentication ---
# Basic auth stays ON so the banking-UI BFF (service account) keeps working while
# users authenticate via Keycloak at the UI layer. Flip to false only after OIDC
# federation below is verified end-to-end.
FINERACT_SECURITY_BASICAUTH_ENABLED=true
FINERACT_SECURITY_OAUTH_ENABLED=false
FINERACT_SERVER_OAUTH_RESOURCE_URL=https://auth.patocapital.com/realms/taalam

# OIDC federation: validate Keycloak-issued JWTs directly in Fineract.
# Keep disabled until ready; then set the issuer/jwk for the tenant realm.
FINERACT_SECURITY_OIDC_FEDERATION_ENABLED=false
FINERACT_SECURITY_OIDC_TENANT_CLAIM=fineract_tenant
FINERACT_SECURITY_OIDC_USERNAME_CLAIM=preferred_username
# SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=https://auth.patocapital.com/realms/taalam
# SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWK_SET_URI=https://auth.patocapital.com/realms/taalam/protocol/openid-connect/certs

# External Keycloak: resource-server validation + per-tenant realm provisioning.
# NOTE: Fineract allows exactly ONE auth scheme. Setting this to true REQUIRES
# FINERACT_SECURITY_BASICAUTH_ENABLED=false (and the banking-UI BFF must then forward
# Keycloak access tokens instead of using a basic-auth service account).
# Kept false here so basic auth (current banking-UI flow) works; flip both together
# to enable Fineract-on-Keycloak + per-tenant realm auto-provisioning.
FINERACT_SECURITY_OAUTH2_EXTERNAL_ENABLED=false
FINERACT_SECURITY_OAUTH2_EXTERNAL_KEYCLOAK_BASE_URL=http://fincore-kc:8080
FINERACT_SECURITY_OAUTH2_EXTERNAL_AUDIENCE=fineract
FINERACT_SECURITY_OAUTH2_EXTERNAL_PROVISIONING_ENABLED=true
FINERACT_SECURITY_OAUTH2_EXTERNAL_PROVISIONING_ADMIN_REALM=master
FINERACT_SECURITY_OAUTH2_EXTERNAL_PROVISIONING_ADMIN_CLIENT_ID=fineract-provisioner
FINERACT_SECURITY_OAUTH2_EXTERNAL_PROVISIONING_ADMIN_CLIENT_SECRET=CHANGE_ME_PROVISIONER_SECRET
FINERACT_SECURITY_OAUTH2_EXTERNAL_PROVISIONING_UI_CLIENT_CLIENT_ID=fincore-web
FINERACT_SECURITY_OAUTH2_EXTERNAL_PROVISIONING_UI_CLIENT_BASE_URL=http://localhost:3000

FINERACT_INSECURE_HTTP_CLIENT=false

FINERACT_HIKARI_DRIVER_SOURCE_CLASS_NAME=org.postgresql.Driver
FINERACT_HIKARI_JDBC_URL=jdbc:postgresql://fincore-pg-db:5432/fineract_tenants
FINERACT_HIKARI_USERNAME=admin
FINERACT_HIKARI_PASSWORD=admin123

FINERACT_HIKARI_MINIMUM_IDLE=10
FINERACT_HIKARI_MAXIMUM_POOL_SIZE=30
FINERACT_HIKARI_CONNECTION_TIMEOUT=30000
FINERACT_HIKARI_IDLE_TIMEOUT=600000
FINERACT_HIKARI_TEST_QUERY=SELECT 1
FINERACT_HIKARI_AUTO_COMMIT=true

SPRING_PROFILES_ACTIVE=prod

FINERACT_SERVER_SSL_ENABLED=true

FINERACT_MANAGEMENT_ENDPOINT_WEB_EXPOSURE_INCLUDE=health,info,prometheus

FINERACT_LIQUIBASE_ENABLED=true

# Fineract run modes (current Fineract uses FINERACT_MODE_* names; the older
# FINERACT_*_MODE_ENABLED names are ignored by current builds).
FINERACT_MODE_READ_ENABLED=true
FINERACT_MODE_WRITE_ENABLED=true
FINERACT_MODE_BATCH_WORKER_ENABLED=true
FINERACT_MODE_BATCH_MANAGER_ENABLED=true

FINERACT_DEFAULT_TENANTDB_HOSTNAME=fincore-pg-db
FINERACT_DEFAULT_TENANTDB_PORT=5432
FINERACT_DEFAULT_TENANTDB_UID=admin
FINERACT_DEFAULT_TENANTDB_PWD=admin123
FINERACT_DEFAULT_TENANTDB_CONN_PARAMS=
FINERACT_DEFAULT_TENANTDB_TIMEZONE=Africa/Nairobi
FINERACT_DEFAULT_TENANTDB_IDENTIFIER=default
FINERACT_DEFAULT_TENANTDB_NAME=fineract_default
FINERACT_DEFAULT_TENANTDB_DESCRIPTION=Default Tenant

JAVA_TOOL_OPTIONS=-Xms1G -Xmx2G

# Reporting template selector for taalam reporting image
# Supported values: postgresql | mariadb
FINERACT_REPORTS_DB_TYPE=postgresql

# Writable filesystem content root for imports/uploads and generated files
FINERACT_CONTENT_FILESYSTEM_ENABLED=true
FINERACT_CONTENT_FILESYSTEM_ROOT_FOLDER=/opt/fineract-content
