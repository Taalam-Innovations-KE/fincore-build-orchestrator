# Shared Keycloak settings (both local and prod).
# Hostname/proxy settings live in compose.prod.yaml (prod) and
# compose.local.yaml (local), since they differ per environment.

KEYCLOAK_IMAGE=taalam/fineract-keycloak-sso:latest

# Admin bootstrap
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin123

# Database
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://fincore-pg-db:5432/keycloak
KC_DB_USERNAME=postgres
KC_DB_PASSWORD=postgres

# HTTP (TLS is terminated at Traefik in prod)
KC_HTTP_ENABLED=true
KC_HTTP_PORT=8080

# Health/metrics
KC_HEALTH_ENABLED=true
KC_METRICS_ENABLED=true
