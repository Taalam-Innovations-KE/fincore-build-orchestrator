# Fineract API (internal only — reached over the fincore network, not published)
FINERACT_BASE_URL=https://fineract:8443/fineract-provider/api
FINERACT_USERNAME=mifos
FINERACT_PASSWORD=password

# NextAuth
# Generate a random secret: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET
AUTH_URL=https://apps.patocapital.com

# Keycloak (per-tenant realm — banking users authenticate in their tenant realm).
# `taalam` is the default tenant realm; the UI swaps the realm segment per tenant.
AUTH_KEYCLOAK_ISSUER=https://auth.patocapital.com/realms/taalam
AUTH_KEYCLOAK_ID=fincore-web
AUTH_KEYCLOAK_SECRET=CHANGE_ME_FINCORE_WEB_CLIENT_SECRET

# Allow the internal self-signed Fineract TLS cert (internal traffic only).
NODE_TLS_REJECT_UNAUTHORIZED=0
