SPRING_PROFILES_ACTIVE=postgres,prod
TENANT_MGMT_IMAGE=taalamke/taalam-tenant-management-service:latest

# --- Service metadata database (this service's own state) ---
TENANT_MGMT_DB_URL=jdbc:postgresql://fincore-pg-db:5432/fineract_tenant_management
TENANT_MGMT_DB_USERNAME=tenant_mgmt
TENANT_MGMT_DB_PASSWORD=admin123

# --- OAuth2 resource server (validates tokens from the platform realm) ---
TENANT_MGMT_SECURITY_ENABLED=true
TENANT_MGMT_SECURITY_ISSUER_URI=https://auth.patocapital.com/realms/platform
TENANT_MGMT_SECURITY_JWK_SET_URI=https://auth.patocapital.com/realms/platform/protocol/openid-connect/certs
TENANT_MGMT_SECURITY_AUDIENCE=fineract-tenant-management
TENANT_MGMT_SECURITY_PERMIT_DOCS=false

# --- Keycloak admin (provisions per-tenant realms + users) ---
TENANT_MGMT_KEYCLOAK_ENABLED=true
TENANT_MGMT_KEYCLOAK_BASE_URL=http://fincore-kc:8080
TENANT_MGMT_KEYCLOAK_REALM=platform
TENANT_MGMT_KEYCLOAK_ADMIN_REALM=master
TENANT_MGMT_KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
TENANT_MGMT_KEYCLOAK_ADMIN_USERNAME=admin
TENANT_MGMT_KEYCLOAK_ADMIN_PASSWORD=admin123

# --- Provisioning: real provisioner (creates tenant DBs + runtime users) ---
TENANT_MGMT_NOOP_PROVISIONER_ENABLED=false
TENANT_MGMT_PROVISIONING_ADMIN_JDBC_URL=jdbc:postgresql://fincore-pg-db:5432/postgres
TENANT_MGMT_PROVISIONING_ADMIN_USERNAME=postgres
TENANT_MGMT_PROVISIONING_ADMIN_PASSWORD=postgres
FINERACT_TENANT_STORE_JDBC_URL=jdbc:postgresql://fincore-pg-db:5432/fineract_tenants
FINERACT_TENANT_STORE_USERNAME=admin
FINERACT_TENANT_STORE_PASSWORD=admin123
TENANT_MGMT_TENANT_DB_HOST=fincore-pg-db
TENANT_MGMT_TENANT_DB_PORT=5432

# --- Fineract runtime registration (registers new tenants with Fineract live) ---
# Authenticated with a Keycloak client-credentials token (client fineract-runtime).
FINERACT_RUNTIME_REFRESH_URL=https://fineract:8443/fineract-provider/api/v1/tenant-runtime/register-and-refresh
FINERACT_RUNTIME_REFRESH_TOKEN_URL=https://auth.patocapital.com/realms/platform/protocol/openid-connect/token
FINERACT_RUNTIME_REFRESH_CLIENT_ID=fineract-runtime
FINERACT_RUNTIME_REFRESH_CLIENT_SECRET=CHANGE_ME_RUNTIME_CLIENT_SECRET
FINERACT_RUNTIME_REFRESH_AUDIENCE=fineract
FINERACT_RUNTIME_REFRESH_INSECURE_TLS=true

# disableHostnameVerification makes the JDK HttpClient honor runtime-refresh-insecure-tls
# for the internal self-signed Fineract cert (whose SAN doesn't include "fineract").
JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -Djdk.internal.httpclient.disableHostnameVerification=true
